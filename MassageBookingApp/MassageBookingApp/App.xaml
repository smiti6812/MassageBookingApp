<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MassageBookingApp"
              xmlns:helpers="clr-namespace:MassageBookingApp.Mobile.Helpers"
             x:Class="MassageBookingApp.App">
    <Application.Resources>
        
        <ResourceDictionary>
            <helpers:BoolToColorConverter x:Key="BoolToColorConverter" />
            <helpers:InverseBoolConverter x:Key="InverseBoolConverter" />
            
            <Color x:Key="OccupiedColor">Coral</Color>
            <Color x:Key="FreeColor">LightGreen</Color>
            <Color x:Key="PrimaryColor">#2C3E50</Color>
            <Color x:Key="AccentColor">#3498DB</Color>
            <Color x:Key="BorderColor">#D0D0D0</Color>
            <Color x:Key="CurrentMonthDayColor">White</Color>
            <Color x:Key="OtherMonthDayColor">#F4F4F4</Color>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
