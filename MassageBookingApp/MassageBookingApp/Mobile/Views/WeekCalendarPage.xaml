<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MassageBookingApp.Mobile.Views.WeekCalendarPage"
             xmlns:models="clr-namespace:MassageBookingApp.Mobile.Models.Calendar"
             Title="Week Calendar">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="12">

        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <Button Grid.Column="0"
                    Text="&lt;"
                    WidthRequest="50"
                    Command="{Binding PreviousWeekCommand}" />

            <Label Grid.Column="1"
                   Text="{Binding Title}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontAttributes="Bold"
                   FontSize="18" />

            <Button Grid.Column="2"
                    Text="&gt;"
                    WidthRequest="50"
                    Command="{Binding NextWeekCommand}" />
        </Grid>

        <Label Grid.Row="1"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding HasError}"
               Margin="0,0,0,8" />

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Days}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:WeekDaySummaryDto">
                    <Frame Padding="12"
                           Margin="0,4"
                           BorderColor="{StaticResource BorderColor}"
                           BackgroundColor="White">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectDayCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding DayName}"
                                   FontAttributes="Bold"
                                   FontSize="18" />

                            <Label Text="{Binding Date, StringFormat='Date: {0:yyyy-MM-dd}'}" />
                            <Label Text="{Binding BookingCount, StringFormat='Bookings: {0}'}" />
                            <Label Text="{Binding TotalMassageMinutes, StringFormat='Massage minutes: {0}'}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="3" ColumnDefinitions="*,*" Margin="0,12,0,0">
            <Button Grid.Column="0"
                    Text="Back to Month"
                    Command="{Binding BackToMonthCommand}" />

            <Button Grid.Column="1"
                    Text="Refresh"
                    Command="{Binding LoadCommand}" />
        </Grid>

        <ActivityIndicator Grid.RowSpan="4"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
</ContentPage>