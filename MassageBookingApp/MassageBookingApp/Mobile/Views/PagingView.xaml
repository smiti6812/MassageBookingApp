<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:MassageBookingApp.Mobile.Helpers"
              xmlns:models="clr-namespace:MassageBookingApp.Mobile.Models"
             x:Class="MassageBookingApp.Mobile.Views.PagingView">
    <ContentView.Resources>
        <converters:SelectedPageMultiConverter x:Key="SelectedPageMultiConverter" />
        <converters:BoolToIsEnabledCollapseColorConverter x:Key="BoolToIsEnabledCollapseColorConverter" />
    </ContentView.Resources>

    <ScrollView Orientation="Horizontal"
             HorizontalScrollBarVisibility="Always"
             Padding="6">
        <HorizontalStackLayout Spacing="4"
                            MaximumHeightRequest="50"                               
                            VerticalOptions="Center">

            <Button Text="First"                    
                 Command="{Binding GoToFirstCommand}"
                 IsEnabled="{Binding CanGoPrevious}" 
                 BackgroundColor="{Binding CanGoPrevious, Converter={StaticResource BoolToIsEnabledCollapseColorConverter}, ConverterParameter='Color'}"/>

            <Button Text="Prev"
                 Command="{Binding PreviousPageCommand}"
                 IsEnabled="{Binding CanGoPrevious}" 
                 BackgroundColor="{Binding CanGoPrevious, Converter={StaticResource BoolToIsEnabledCollapseColorConverter}, ConverterParameter='Color'}"/>

            <Label Text="{Binding RoomDisplayText}"
                VerticalOptions="Center"
                FontAttributes="Bold"
                FontSize="10" />

            <CollectionView ItemsSource="{Binding PagingItems}"
                         SelectionMode="Single"
                         SelectedItem="{Binding SelectedPage, Mode=TwoWay}"
                         HorizontalOptions="Center">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="2" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:PagingItem">
                        <Grid>
                            <Button Text="{Binding DisplayText}"  MaximumWidthRequest="80"
                                 Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.JumpToPageCommand}"
                                 CommandParameter="{Binding Value}">
                                <Button.BackgroundColor>
                                    <MultiBinding Converter="{StaticResource SelectedPageMultiConverter}">
                                        <Binding Path="Value" />
                                        <Binding Path="BindingContext.SelectedPage"
                                              Source="{RelativeSource AncestorType={x:Type ContentView}}" />
                                    </MultiBinding>
                                </Button.BackgroundColor>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Next"
                 Command="{Binding NextPageCommand}"
                 IsEnabled="{Binding CanGoNext}" 
                 BackgroundColor="{Binding CanGoNext, Converter={StaticResource BoolToIsEnabledCollapseColorConverter}, ConverterParameter='Color'}"/>

            <Button Text="Last"
                 Command="{Binding GoToLastCommand}"
                 IsEnabled="{Binding CanGoNext}" 
                 BackgroundColor="{Binding CanGoNext, Converter={StaticResource BoolToIsEnabledCollapseColorConverter}, ConverterParameter='Color'}"/>
        </HorizontalStackLayout>
    </ScrollView>
</ContentView>