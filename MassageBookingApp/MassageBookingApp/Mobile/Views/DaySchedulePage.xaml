<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MassageBookingApp.Mobile.Views.DaySchedulePage"
             xmlns:models="clr-namespace:MassageBookingApp.Mobile.Models.Calendar"
             xmlns:viewModel="clr-namespace:MassageBookingApp.Mobile.ViewModels"
             xmlns:controls="clr-namespace:MassageBookingApp.Mobile.Views"
             Title="Day Schedule">
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="12">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <Button Grid.Column="0"
                    BackgroundColor="{StaticResource Cornflower}"
                    TextColor="White"
                    Text="&lt;"
                    WidthRequest="50"
                    Command="{Binding PreviousDayCommand}" />

            <Label Grid.Column="1"
                   Text="{Binding Title}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontAttributes="Bold"
                   FontSize="18" />

            <Button Grid.Column="2"
                    BackgroundColor="{StaticResource Cornflower}"
                    TextColor="White"
                    Text="&gt;"
                    WidthRequest="50"
                    Command="{Binding NextDayCommand}" />
        </Grid>

        <!-- Error -->
        <Label Grid.Row="1"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding HasError}"
               Margin="0,0,0,8" />

        <!-- Generic pager -->       
        <controls:PagingView Grid.Row="2" PagingViewModel="{Binding RoomPager}" />
        
        <!-- Current room content -->
        <ScrollView Grid.Row="3">
            <VerticalStackLayout Spacing="12">

                <Button Text="New Booking"
                        BackgroundColor="{StaticResource Cornflower}"
                        TextColor="White"
                        Command="{Binding OpenNewBookingCommand}" />

                <Frame Padding="10"
                       BorderColor="{StaticResource BorderColor}"
                       BackgroundColor="White"
                       IsVisible="{Binding CurrentRoom, Converter={StaticResource NotNullConverter}}">

                    <VerticalStackLayout Spacing="8">

                        <HorizontalStackLayout Spacing="8">
                            <Label Text="{Binding CurrentRoom.RoomName}"
                                   FontAttributes="Bold"
                                   FontSize="22" />

                            <Label Text="{Binding CurrentRoom.RoomCapacity, StringFormat='(Capacity: {0})'}"
                                   FontSize="18"
                                   TextColor="Gray" />
                        </HorizontalStackLayout>

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding CurrentRoom.Stations}" Spacing="12">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewModel:RoomStationScheduleViewModel">
                                    <Frame Padding="8"
                                           BorderColor="{StaticResource BorderColor}"
                                           BackgroundColor="#FAFAFA">
                                        <VerticalStackLayout Spacing="8">

                                            <Label Text="{Binding RoomStationName}"
                                                   FontAttributes="Bold"
                                                   FontSize="16" />

                                            <CollectionView ItemsSource="{Binding Cells}"
                                                            SelectionMode="None">
                                                <CollectionView.ItemsLayout>
                                                    <GridItemsLayout Orientation="Vertical" Span="3" />
                                                </CollectionView.ItemsLayout>

                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:DayScheduleCellDto">
                                                        <Frame Padding="6"
                                                               Margin="2"
                                                               BackgroundColor="{Binding BackgroundColor}"
                                                               BorderColor="{StaticResource BorderColor}">
                                                            <Frame.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectCellCommand}"
                                                                    CommandParameter="{Binding .}" />
                                                            </Frame.GestureRecognizers>

                                                            <VerticalStackLayout Spacing="2">
                                                                <Label Text="{Binding TimeSlot}"
                                                                       FontSize="12"
                                                                       FontAttributes="Bold" />

                                                                <Label Text="{Binding ClientName}"
                                                                       FontSize="11"
                                                                       FontAttributes="Bold"
                                                                       LineBreakMode="TailTruncation" />

                                                                <Label Text="{Binding TherapistName}"
                                                                       FontSize="10"
                                                                       LineBreakMode="TailTruncation" />
                                                            </VerticalStackLayout>
                                                        </Frame>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>
                                    </Frame>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer -->
        <Grid Grid.Row="4" ColumnDefinitions="*,*,*" Margin="0,12,0,0">
            <Button Grid.Column="0"
                    Margin="2"
                    BackgroundColor="{StaticResource Cornflower}"
                    TextColor="White"
                    Text="Month"
                    Command="{Binding BackToMonthCommand}" />

            <Button Grid.Column="1"
                    Margin="2"
                    BackgroundColor="{StaticResource Cornflower}"
                    TextColor="White"
                    Text="Week"
                    Command="{Binding BackToWeekCommand}" />

            <Button Grid.Column="2"
                    Margin="2"
                    BackgroundColor="{StaticResource Cornflower}"
                    TextColor="White"
                    Text="Refresh"
                    Command="{Binding LoadCommand}" />
        </Grid>

        <ActivityIndicator Grid.RowSpan="5"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
</ContentPage>