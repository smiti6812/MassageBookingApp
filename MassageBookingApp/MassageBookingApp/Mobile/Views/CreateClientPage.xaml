<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MassageBookingApp.Mobile.Views.CreateClientPage"
             Title="Create Client">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="New Client"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="Full Name" />
            <Entry Text="{Binding FullName}"
                   Placeholder="Client full name" />

            <Label Text="Phone Number" />
            <Entry Text="{Binding PhoneNumber}"
                   Placeholder="Phone number"
                   Keyboard="Telephone" />

            <Label Text="Notes" />
            <Editor Text="{Binding Notes}"
                    HeightRequest="120"
                    AutoSize="TextChanges" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <Grid ColumnDefinitions="*,*" Margin="0,12,0,0">
                <Button Margin="2" Grid.Column="0"
                        BackgroundColor="{StaticResource Cornflower}"
                        TextColor="White"
                        Text="Save"
                        Command="{Binding SaveCommand}" />

                <Button Margin="2" Grid.Column="1"
                        BackgroundColor="{StaticResource Cornflower}"
                        TextColor="White"
                        Text="Cancel"
                        Command="{Binding CancelCommand}" />
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>